{
  "name": "@minyanim/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply minyanim --local",
    "db:migrate:remote": "wrangler d1 migrations apply minyanim --remote"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@minyanim/shared": "workspace:*",
    "@photostructure/tz-lookup": "^11.5.0",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.12",
    "kosher-zmanim": "^0.9.0",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.36",
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3",
    "vitest": "2.1.8",
    "wrangler": "^4.0.0"
  }
}

{
  "name": "@minyanim/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply minyanim --local",
    "db:migrate:remote": "wrangler d1 migrations apply minyanim --remote"
  },
  "dependencies": {
    "@minyanim/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.36",
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "vitest": "2.1.8",
    "wrangler": "^4.0.0"
  }
}

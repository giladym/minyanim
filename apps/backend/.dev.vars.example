# Copy to `.dev.vars` (git-ignored) and fill in. See docs/secrets.md + docs/integrations/.
# Secrets are read via the Worker `env` binding — never committed, never in client code.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
BETTER_AUTH_SECRET=""
RESEND_API_KEY=""
MAPTILER_API_KEY=""
# PUBLIC map-tile key (origin-restricted, usage-capped) — served to the client via GET /api/config.
# Not a secret, but kept here so all key config lives in one place. Deployed envs set it as a var.
MAPTILER_TILE_KEY=""
